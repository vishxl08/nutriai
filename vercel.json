{
  "version": 2,
  "builds": [
    {
      "src": "nutriai_dj/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/tracker/static/$1"
    },
    {
      "src": "/media/(.*)",
      "dest": "/media/$1"
    },
    {
      "src": "/(.*)",
      "dest": "nutriai_dj/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "nutriai_dj.settings",
    "DEBUG": "False"
  }
}